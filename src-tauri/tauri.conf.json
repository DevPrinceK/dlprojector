{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DL Projector",
  "version": "0.1.0",
  "identifier": "org.dlcflegon.dlprojector",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DL Projector Control",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true
      },
      {
        "label": "projection",
        "title": "DL Projector Output",
        "url": "index.html",
        "width": 1280,
        "height": 720,
        "minWidth": 800,
        "minHeight": 450,
        "resizable": true,
        "visible": false,
        "focus": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "DLCF Legon",
    "category": "Utility",
    "shortDescription": "Offline church projection software",
    "longDescription": "DLCF Legon Projection Software for scriptures, hymns, announcements, and service programs."
  }
}
