{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DL Projector",
  "version": "0.1.7",
  "identifier": "org.dlcflegon.dlprojector",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DL Projector Control",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true
      },
      {
        "label": "projection",
        "title": "DL Projector Output",
        "url": "index.html",
        "width": 1280,
        "height": 720,
        "minWidth": 800,
        "minHeight": 450,
        "resizable": true,
        "visible": false,
        "focus": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; connect-src 'self' ipc: http://ipc.localhost https://api.github.com https://raw.githubusercontent.com; img-src 'self' asset: http://asset.localhost data: blob: https:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/org.dlcflegon.dlprojector/media/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "PKay Software Consultancy",
    "category": "Utility",
    "shortDescription": "Offline church projection software",
    "longDescription": "Professional offline-first church projection software for scriptures, hymns, announcements, media, and service programs.",
    "windows": {
      "allowDowngrades": false,
      "nsis": {
        "headerImage": "installer-assets/header.bmp",
        "sidebarImage": "installer-assets/sidebar.bmp",
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "uninstallerHeaderImage": "installer-assets/header.bmp",
        "installMode": "currentUser",
        "languages": [
          "English"
        ],
        "compression": "lzma",
        "startMenuFolder": "PKay Software Consultancy"
      }
    }
  }
}
